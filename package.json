{
  "name": "ember-native-demo",
  "main": "app/boot.js",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev:ios": "concurrently -k -n vite,ns \"npm run dev:server:ios\" \"wait-on tcp:5173 && npm run ios\"",
    "dev:android": "concurrently -k -n vite,ns \"npm run dev:server:android\" \"wait-on tcp:5173 && npm run android\"",
    "dev:server:ios": "vite serve -- --env.ios --env.hmr",
    "dev:server:android": "vite serve -- --env.android --env.hmr",
    "ios": "ns debug ios",
    "android": "ns debug android",
    "devtools": "ember-devtools",
    "run": "ns debug android",
    "build": "ns build android",
    "test": "ns test android",
    "debug-test": "ns test android --debug-brk",
    "debug": "ns debug android --debug-brk",
    "prepare-android": "ns prepare android",
    "lint": "concurrently 'pnpm:lint:*(!fix)' --names 'lint:'",
    "lint:fix": "concurrently 'pnpm:lint:*:fix' --names 'fix:'",
    "lint:hbs": "ember-template-lint . --no-error-on-unmatched-pattern",
    "lint:hbs:fix": "ember-template-lint . --fix --no-error-on-unmatched-pattern",
    "lint:js": "eslint .",
    "lint:js:fix": "eslint . --fix",
    "lint:types": "glint",
    "debug:types": "glint --debug-intermediate-representation",
    "prebuild": "EMBROIDER_PREBUILD=true pnpm ember build"
  },
  "dependencies": {
    "@ember/test-waiters": "^4.1.1",
    "@embroider/macros": "^1.19.5",
    "@nativescript/core": "~9.0.18",
    "@nativescript/theme": "^3.1.0",
    "@nativescript/unit-test-runner": "~3.0.0",
    "@valor/nativescript-websockets": "^2.0.2",
    "@warp-drive/core": "^5.8.1",
    "@warp-drive/core-types": "^0.0.0-beta.20",
    "@warp-drive/json-api": "^5.8.1",
    "chromedriver": "^137.0.1",
    "ember-compatibility-helpers": "^1.2.7",
    "ember-load-initializers": "^3.0.1",
    "ember-modifier": "^4.2.0",
    "ember-native": "^3.1.0",
    "ember-native-devtools": "^1.0.3",
    "ember-source": "^6.12.0",
    "nativescript-ui-listview": "^15.2.3",
    "nativescript-ui-sidedrawer": "^15.2.3",
    "octokit": "^5.0.5",
    "selenium-webdriver": "^4.34.0"
  },
  "devDependencies": {
    "@babel/core": "^7.28.5",
    "@babel/eslint-parser": "^7.28.5",
    "@babel/plugin-transform-runtime": "^7.28.5",
    "@babel/plugin-transform-typescript": "^7.28.5",
    "@ember/test-helpers": "^5.2.2",
    "@embroider/compat": "^4.1.0",
    "@embroider/core": "^4.4.7",
    "@embroider/vite": "^1.4.4",
    "@eslint/js": "^9.39.1",
    "@glimmer/component": "^2.0.0",
    "@glimmer/validator": "^0.95.0",
    "@glint/core": "^1.5.2",
    "@glint/environment-ember-template-imports": "^1.5.2",
    "@jsdevtools/coverage-istanbul-loader": "3.0.5",
    "@nativescript/android": "9.0.2",
    "@nativescript/core": "^9.0.18",
    "@nativescript/types": "~8.9.1",
    "@nativescript/vite": "2.0.1",
    "@nativescript/webpack": "^5.0.33",
    "@types/qunit": "2.19.13",
    "babel-import-util": "^3.0.1",
    "babel-loader": "^10.0.0",
    "babel-plugin-ember-template-compilation": "^3.0.0",
    "browserify-fs": "^1.0.0",
    "buffer": "^6.0.3",
    "concurrently": "^9.2.1",
    "content-tag": "^4.0.0",
    "css-loader": "^7.1.2",
    "decorator-transforms": "^2.3.0",
    "ember-auto-import": "^2.13.1",
    "ember-cli": "^6.12.0",
    "ember-cli-version-checker": "^5.1.2",
    "ember-qunit": "^9.0.4",
    "ember-resolver": "^13.1.1",
    "ember-routable-component": "^1.2.0",
    "ember-template-lint": "^7.9.2",
    "ember-vite-hmr": "^2.0.7",
    "esbuild": "0.27.7",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-ember": "^12.7.5",
    "eslint-plugin-n": "^17.21.0",
    "eslint-plugin-qunit": "^8.2.5",
    "globals": "^16.3.0",
    "https-browserify": "^1.0.0",
    "karma": "^4.4.1",
    "karma-coverage": "2.2.1",
    "karma-nativescript-launcher": "1.0.0",
    "karma-qunit": "4.2.1",
    "nativescript": "^9.0.5",
    "nyc": "17.1.0",
    "path-browserify": "^1.0.1",
    "querystring-es3": "^0.2.1",
    "qunit": "^2.25.0",
    "qunit-dom": "^3.5.0",
    "rollup": "^4.53.3",
    "socket.io": "^4.8.1",
    "stream-browserify": "^3.0.0",
    "stream-http": "^3.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.49.0",
    "url": "^0.11.4",
    "util": "^0.12.5",
    "vite": "^7.3.2",
    "wait-on": "^9.0.5"
  },
  "exports": {
    "./tests/*": "./tests/*",
    "./*": "./app/*"
  },
  "browser": {
    "fs": false,
    "path": false,
    "os": false
  },
  "pnpm": {
    "ignoredBuiltDependencies": [
      "core-js",
      "@nativescript/core",
      "@nativescript/unit-test-runner",
      "chromedriver",
      "@parcel/watcher",
      "core-js-pure",
      "nativescript"
    ],
    "onlyBuiltDependencies": [
      "core-js",
      "@nativescript/core",
      "@nativescript/unit-test-runner",
      "chromedriver",
      "@parcel/watcher",
      "core-js-pure",
      "nativescript"
    ],
    "patchedDependencies": {
      "@nativescript/unit-test-runner": "patches/@nativescript__unit-test-runner.patch"
    }
  },
  "ember": {
    "edition": "octane"
  }
}
